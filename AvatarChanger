APPLYAVATAR = function(userid)
    task.spawn(function()
        xpcall(function()
            INPUT_TEXT = tostring(userid):gsub("%s+","")
            ID = tonumber(INPUT_TEXT)
            NAME = nil
            if ID then
                SUCCESS = pcall(function() NAME = SVC.Players:GetNameFromUserIdAsync(ID) end)
                if not SUCCESS or not NAME then return end
            else
                SUCCESS = pcall(function()
                    ID = SVC.Players:GetUserIdFromNameAsync(INPUT_TEXT)
                    NAME = SVC.Players:GetNameFromUserIdAsync(ID)
                end)
                if not SUCCESS or not NAME or not ID then return end
            end
            DESC = SVC.Players:GetHumanoidDescriptionFromUserId(ID)
            CURRENT_AVATAR = {id=ID,name=NAME,desc=DESC}
            if LP.Character then MORPHCHAR(LP.Character,NAME,ID,DESC) end
            LP.CharacterAdded:Connect(function(char)
                if CURRENT_AVATAR and CURRENT_AVATAR.id == ID then MORPHCHAR(char,NAME,ID,DESC) end
            end)
            UPDATEFAVBTN()
        end,warn)
    end)
end

