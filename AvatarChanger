FAV_BTN.MouseButton1Click:Connect(function()
    if not CURRENT_AVATAR then return end
    EXISTS = false
    IDX = 0
    for i,v in FAVORITES do
        if v.id == CURRENT_AVATAR.id then EXISTS = true IDX = i break end
    end
    if EXISTS then
        table.remove(FAVORITES,IDX)
    else
        table.insert(FAVORITES,CURRENT_AVATAR)
    end
    SAVEFAVORITES()
    UPDATEFAVBTN()
    UPDATEFAVLIST()
end)

